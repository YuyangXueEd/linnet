---
interface Props {
  current?: 'daily' | 'weekly' | 'monthly' | 'setup';
  lang?: string;
}

const { current, lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isZh = lang === 'zh-CN' || lang === 'zh';

const links = isZh
  ? [
      { key: 'daily',   href: `${base}/daily/`,    label: '日报' },
      { key: 'weekly',  href: `${base}/weekly/`,   label: '周报' },
      { key: 'monthly', href: `${base}/monthly/`,  label: '月报' },
      { key: 'setup',   href: `${base}/setup/zh/`, label: '配置' },
    ]
  : [
      { key: 'daily',   href: `${base}/daily/`,   label: 'Daily' },
      { key: 'weekly',  href: `${base}/weekly/`,  label: 'Weekly' },
      { key: 'monthly', href: `${base}/monthly/`, label: 'Monthly' },
      { key: 'setup',   href: `${base}/setup/`,   label: 'Setup' },
    ];

const homeHref   = isZh ? `${base}/zh/` : `${base}/`;
const langHref   = isZh
  ? (current === 'setup' ? `${base}/setup/`    : `${base}/`)
  : (current === 'setup' ? `${base}/setup/zh/` : `${base}/zh/`);
const langLabel  = isZh ? 'EN' : '中';
---

<nav class="navbar">
  <div class="navbar-inner page-wrap">
    <a href={homeHref} class="navbar-brand" aria-label="Linnet home">
      <img src={`${base}/favicon.svg`} class="navbar-logo" alt="Linnet bird logo" width="28" height="28" />
      <span class="navbar-name" lang="en">Linnet</span>
    </a>

    <div class="navbar-links">
      {links.map(({ key, href, label }) => (
        <a
          href={href}
          class:list={['navbar-link', { 'navbar-link--active': current === key }]}
        >
          {label}
        </a>
      ))}
    </div>

    <div class="navbar-controls">
      <a href={langHref} class="navbar-lang-btn" aria-label="Switch language">{langLabel}</a>
      <button id="theme-toggle" class="navbar-theme-btn" aria-label="Toggle theme">
      <span class="theme-icon-sun">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.5 5.5l1.4 1.4M17.1 17.1l1.4 1.4M5.5 18.5l1.4-1.4M17.1 6.9l1.4-1.4"/>
        </svg>
      </span>
      <span class="theme-icon-moon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 14.5A8 8 0 0 1 9.5 4a8 8 0 1 0 10.5 10.5z"/>
        </svg>
      </span>
    </button>
    </div>
  </div>
</nav>

<script>
const btn = document.getElementById('theme-toggle');
const initial = localStorage.getItem('theme') || 'light';

document.documentElement.dataset.theme = initial;

btn?.addEventListener('click', () => {
  const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
  document.documentElement.dataset.theme = next;
  localStorage.setItem('theme', next);
});
</script>

<style>
.navbar {
  position: sticky;
  top: 0;
  z-index: 50;
  height: var(--nav-height);
  background: rgba(244, 237, 224, 0.88);
  border-bottom: 1px solid var(--rule);
  backdrop-filter: blur(16px);
}

[data-theme="dark"] .navbar {
  background: rgba(28, 22, 17, 0.88);
}

.navbar-inner {
  display: flex;
  align-items: center;
  height: 100%;
  gap: 1.5rem;
}

.navbar-brand {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none !important;
  color: var(--ink);
  flex-shrink: 0;
}

.navbar-logo {
  width: 28px;
  height: 28px;
  object-fit: contain;
  flex-shrink: 0;
}

/* Dark mode: make dark SVG paths visible on dark background */
[data-theme="dark"] .navbar-logo {
  filter: invert(1);
}

.navbar-name {
  /* Explicit stack prevents CJK browser substitution when lang="zh-CN" */
  font-family: "Fraunces", "Charter", Georgia, ui-serif;
  font-size: 1.375rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--ink);
}

.navbar-links {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-left: 1.5rem;
}

.navbar-link {
  padding: 5px 12px;
  font-family: var(--font-mono);
  font-size: 0.69rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  text-decoration: none;
  border-bottom: 1.5px solid transparent;
  transition: color 0.15s, border-color 0.15s;
}

.navbar-link:hover {
  color: var(--ink);
  text-decoration: none;
}

.navbar-link--active {
  color: var(--accent);
  font-weight: 700;
  border-bottom-color: var(--accent);
}

.navbar-controls {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}

.navbar-lang-btn,
.navbar-theme-btn {
  background: transparent;
  border: 1px solid var(--rule);
  border-radius: 999px;
  width: 32px;
  height: 32px;
  display: grid;
  place-items: center;
  cursor: pointer;
  color: var(--ink-muted);
  flex-shrink: 0;
  transition: color 0.15s, border-color 0.15s;
  text-decoration: none;
}

.navbar-lang-btn {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.04em;
}

.navbar-lang-btn:hover,
.navbar-theme-btn:hover {
  color: var(--ink);
  border-color: var(--ink-muted);
  text-decoration: none;
}

/* Show sun in dark mode, moon in light mode */
.theme-icon-sun { display: none; }
.theme-icon-moon { display: grid; place-items: center; }

[data-theme="dark"] .theme-icon-sun { display: grid; place-items: center; }
[data-theme="dark"] .theme-icon-moon { display: none; }

@media (max-width: 480px) {
  .navbar-link { padding: 5px 8px; font-size: 0.65rem; }
  .navbar-name { font-size: 1.1rem; }
}
</style>
