---
interface Props {
  job: {
    title?: string;
    institution?: string;
    location?: string;
    deadline?: string;
    url?: string;
    description?: string;
    summary?: string;
    source?: string;
  };
}
const { job } = Astro.props;
const desc = job.summary ?? job.description ?? '';
---

<div class="job-card">
  <div class="job-card__header">
    <h3 class="job-card__title">
      {job.url
        ? <a href={job.url} target="_blank" rel="noopener">{job.title ?? 'Untitled position'}</a>
        : (job.title ?? 'Untitled position')
      }
    </h3>
    {job.deadline && (
      <div class="job-card__deadline">Deadline {job.deadline}</div>
    )}
  </div>

  {(job.institution || job.location) && (
    <div class="job-card__meta">
      {job.institution && <span>{job.institution}</span>}
      {job.location && <span>{job.location}</span>}
    </div>
  )}

  {desc && <p class="job-card__desc">{desc}</p>}
</div>

<style>
.job-card {
  padding: 20px 0;
  border-bottom: 1px solid var(--rule);
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.job-card__header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 20px;
}

.job-card__title {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 600;
  letter-spacing: -0.01em;
  line-height: 1.25;
  color: var(--ink);
  margin: 0;
}

.job-card__title a {
  color: inherit;
  text-decoration: none;
}

.job-card__title a:hover { color: var(--accent); text-decoration: none; }

.job-card__deadline {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
  white-space: nowrap;
  flex-shrink: 0;
}

.job-card__meta {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.06em;
  color: var(--ink-muted);
  display: flex;
  gap: 6px;
}

.job-card__meta span + span::before {
  content: '·';
  margin-right: 6px;
  color: var(--rule);
}

.job-card__desc {
  font-family: var(--font-body);
  font-size: 0.91rem;
  color: var(--ink-soft);
  line-height: 1.6;
  margin: 4px 0 0;
}
</style>
