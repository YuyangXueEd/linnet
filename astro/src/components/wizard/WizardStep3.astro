---
import type { ExtensionMeta } from '@/lib/registry';

interface Props {
  extensions: ExtensionMeta[];
  locale: 'en' | 'zh';
}
const { extensions, locale } = Astro.props;

const PROVIDER_OPTIONS = [
  {
    value: 'openrouter',
    label: 'OpenRouter',
    baseUrl: 'https://openrouter.ai/api/v1',
    secretName: 'OPENROUTER_API_KEY',
    scoringModel: 'google/gemini-2.5-flash-lite-preview-09-2025',
    summarizationModel: 'google/gemini-2.5-flash-lite-preview-09-2025',
    models: ['google/gemini-2.5-flash-lite-preview-09-2025'],
    note: locale === 'zh'
      ? '默认推荐路径。一个 key 可以切换多家模型，最适合第一次上手。'
      : 'Recommended default. One key can access multiple model families, which keeps first-time setup simple.',
  },
  {
    value: 'openai',
    label: 'OpenAI',
    baseUrl: 'https://api.openai.com/v1',
    secretName: 'OPENAI_API_KEY',
    scoringModel: 'gpt-5-mini',
    summarizationModel: 'gpt-5-mini',
    models: ['gpt-5-mini', 'gpt-5-nano', 'gpt-4.1-mini'],
    note: locale === 'zh'
      ? '适合直接接 OpenAI API。这里默认给你便宜一点的 mini 系列。'
      : 'Use this for the direct OpenAI API. Defaults favour the cheaper mini tier.',
  },
  {
    value: 'anthropic_compat',
    label: locale === 'zh' ? 'Anthropic（OpenAI 兼容）' : 'Anthropic (OpenAI-compatible)',
    baseUrl: 'https://api.anthropic.com/v1/',
    secretName: 'ANTHROPIC_API_KEY',
    scoringModel: 'claude-haiku-4-5',
    summarizationModel: 'claude-haiku-4-5',
    models: ['claude-haiku-4-5', 'claude-sonnet-4-6'],
    note: locale === 'zh'
      ? '当前仓库可以通过 OpenAI 兼容层接 Claude，但更偏向“兼容接入”，不是 Anthropic 原生 SDK 路径。'
      : 'This repo can use Claude through Anthropic’s OpenAI compatibility layer, not the native Anthropic SDK path.',
  },
  {
    value: 'google_compat',
    label: locale === 'zh' ? 'Google Gemini（OpenAI 兼容）' : 'Google Gemini (OpenAI-compatible)',
    baseUrl: 'https://generativelanguage.googleapis.com/v1beta/openai/',
    secretName: 'GEMINI_API_KEY',
    scoringModel: 'gemini-2.5-flash-lite',
    summarizationModel: 'gemini-2.5-flash-lite',
    models: ['gemini-2.5-flash-lite', 'gemini-2.5-flash'],
    note: locale === 'zh'
      ? 'Gemini 的 OpenAI 兼容接口可直接接入当前 Python 逻辑，但官方文档仍把这条路标成 beta。'
      : 'Gemini’s OpenAI-compatible endpoint fits the current Python flow, though Google still marks it as beta.',
  },
  {
    value: 'custom',
    label: locale === 'zh' ? '自定义 OpenAI-compatible' : 'Custom OpenAI-compatible',
    baseUrl: 'https://api.example.com/v1',
    secretName: 'LLM_API_KEY',
    scoringModel: '',
    summarizationModel: '',
    models: [],
    note: locale === 'zh'
      ? '如果你有自己的 OpenAI-compatible gateway，可以直接改 base URL、secret 名称和模型 ID。'
      : 'If you have your own OpenAI-compatible gateway, edit the base URL, secret name, and model IDs directly.',
  },
];

const t = {
  weeklyHead:  locale === 'zh' ? '周报' : 'Weekly',
  monthlyHead: locale === 'zh' ? '月报' : 'Monthly',
  enable:      locale === 'zh' ? '启用' : 'Include',
  topN:        locale === 'zh' ? '条目数' : 'Top N',
  desc:        locale === 'zh'
    ? '先确认 LLM provider / model，再选择哪些来源应汇入每周和每月回顾摘要。'
    : 'Set up the LLM endpoint first, then choose which sources should roll into weekly and monthly digests.',
  llmHead:     locale === 'zh' ? 'LLM 设置' : 'LLM setup',
  llmDesc:     locale === 'zh'
    ? '这里决定 wizard 生成的 llm.provider / base_url / model 配置，以及部署时要写入的 API key secret。'
    : 'This controls the generated llm.provider / base_url / model settings and the API key secret written during deploy.',
  providerLabel: locale === 'zh' ? 'Provider 预设' : 'Provider preset',
  providerHint:  locale === 'zh'
    ? '优先支持 OpenAI-compatible 接口；切换预设时会同步默认模型和 secret 名称。'
    : 'The current backend is built around OpenAI-compatible endpoints; switching presets also updates the default models and secret name.',
  baseUrlLabel:  locale === 'zh' ? 'Base URL' : 'Base URL',
  baseUrlHint:   locale === 'zh'
    ? '如果你走自建 gateway，也可以直接改这里。'
    : 'You can edit this directly if you are routing through a custom gateway.',
  secretLabel:   locale === 'zh' ? 'GitHub Secret 名称' : 'GitHub secret name',
  secretHint:    locale === 'zh'
    ? '生成的 `sources.yaml` 会记录这个环境变量名，部署时也会按这个名字写入 GitHub Actions Secrets。'
    : 'The generated `sources.yaml` stores this env var name, and deploy uses the same name for GitHub Actions secrets.',
  apiKeyLabel:   locale === 'zh' ? 'API key 值' : 'API key value',
  apiKeyFor:     locale === 'zh' ? '对应 secret' : 'Secret name',
  apiKeyHint:    locale === 'zh'
    ? '只在一键部署时用于写入 GitHub Actions Secret，不会写进 YAML。'
    : 'Used only for one-click deploy to write a GitHub Actions secret. Never written into YAML.',
  scoreModelLabel: locale === 'zh' ? '评分模型' : 'Scoring model',
  summaryModelLabel: locale === 'zh' ? '摘要模型' : 'Summarization model',
  modelHint:     locale === 'zh'
    ? '可以直接输入任意模型 ID；默认先给便宜、够用的小模型。'
    : 'You can type any model ID directly; the defaults lean toward cheaper small models.',
  scheduleHead: locale === 'zh' ? '周报 / 月报汇总' : 'Weekly / monthly rollups',
  scheduleDesc: locale === 'zh'
    ? '选择哪些来源应汇入每周和每月回顾摘要。'
    : 'Choose which sources roll up into weekly and monthly digests for slower review.',
};
---

<div class="wz-step" data-step="3" aria-hidden="true">
  <p class="wz-step__desc">{t.desc}</p>

  <div class="wz-stack">
    <div class="wz-card">
      <h3>{t.llmHead}</h3>
      <p class="wz-card__desc">{t.llmDesc}</p>

      <div class="wz-field-row">
        <div class="wz-field">
          <label for="llm-provider">{t.providerLabel}</label>
          <select id="llm-provider" data-llm-provider>
            {PROVIDER_OPTIONS.map((option) => (
              <option
                value={option.value}
                selected={option.value === 'openrouter'}
                data-base-url={option.baseUrl}
                data-secret-name={option.secretName}
                data-scoring-model={option.scoringModel}
                data-summarization-model={option.summarizationModel}
                data-models={JSON.stringify(option.models)}
                data-note={option.note}
              >
                {option.label}
              </option>
            ))}
          </select>
          <div class="wz-field__hint">{t.providerHint}</div>
        </div>
        <div class="wz-field">
          <label for="llm-base-url">{t.baseUrlLabel}</label>
          <input id="llm-base-url" type="url" data-llm-base-url value={PROVIDER_OPTIONS[0].baseUrl} />
          <div class="wz-field__hint">{t.baseUrlHint}</div>
        </div>
        <div class="wz-field">
          <label for="llm-secret-name">{t.secretLabel}</label>
          <input id="llm-secret-name" type="text" data-llm-secret-name value={PROVIDER_OPTIONS[0].secretName} />
          <div class="wz-field__hint">{t.secretHint}</div>
        </div>
      </div>

      <div class="wz-field-row" style="margin-top:18px">
        <div class="wz-field">
          <label for="llm-api-key">{t.apiKeyLabel}</label>
          <div class="wz-field__hint">
            {t.apiKeyFor}: <code data-llm-secret-code>OPENROUTER_API_KEY</code>
          </div>
          <input id="llm-api-key" type="password" data-llm-api-key placeholder="sk-..." autocomplete="off" />
          <div class="wz-field__hint" data-llm-api-key-hint>{t.apiKeyHint}</div>
        </div>
        <div class="wz-field">
          <label for="llm-scoring-model">{t.scoreModelLabel}</label>
          <input
            id="llm-scoring-model"
            type="text"
            data-llm-scoring-model
            list="llm-model-options"
            value={PROVIDER_OPTIONS[0].scoringModel}
          />
        </div>
        <div class="wz-field">
          <label for="llm-summarization-model">{t.summaryModelLabel}</label>
          <input
            id="llm-summarization-model"
            type="text"
            data-llm-summarization-model
            list="llm-model-options"
            value={PROVIDER_OPTIONS[0].summarizationModel}
          />
          <datalist id="llm-model-options" data-llm-model-options>
            {PROVIDER_OPTIONS[0].models.map((model) => (
              <option value={model}></option>
            ))}
          </datalist>
          <div class="wz-field__hint">{t.modelHint}</div>
        </div>
      </div>

      <div class="wz-notice wz-notice--info" style="margin-top:18px" data-llm-provider-note>
        {PROVIDER_OPTIONS[0].note}
      </div>
    </div>

    <div class="wz-card">
      <h3>{t.scheduleHead}</h3>
      <p class="wz-card__desc">{t.scheduleDesc}</p>

      <div class="wz-schedule-table" role="table" aria-label="Schedule preferences">
        <div class="wz-schedule-table__head" role="row">
          <div role="columnheader">{locale === 'zh' ? '来源' : 'Source'}</div>
          <div role="columnheader">{t.weeklyHead}</div>
          <div role="columnheader">{t.monthlyHead}</div>
        </div>

        {extensions.map(ext => {
          const name = locale === 'zh' ? (ext.displayNameZh ?? ext.displayName) : ext.displayName;
          const weekDefault  = ext.weeklyDefault  ?? false;
          const monthDefault = ext.monthlyDefault ?? false;
          const weekTopN     = ext.weeklyTopN  ?? 5;
          const monthTopN    = ext.monthlyTopN ?? 5;
          return (
            <div
              class="wz-schedule-row"
              data-schedule-for={ext.key}
              role="row"
              hidden
            >
              <div class="wz-schedule-row__name" role="cell">{name}</div>

              <div class="wz-schedule-cell" role="cell">
                <label class="wz-toggle">
                  <input
                    type="checkbox"
                    data-schedule-weekly-enabled={ext.key}
                    checked={weekDefault}
                  />
                  <span class="wz-toggle__label">{t.enable}</span>
                </label>
                <div class="wz-schedule-topn">
                  <label for={`weekly-topn-${ext.key}`}>{t.topN}</label>
                  <input
                    type="number"
                    id={`weekly-topn-${ext.key}`}
                    min="1"
                    max="20"
                    value={weekTopN}
                    data-schedule-weekly-topn={ext.key}
                  />
                </div>
              </div>

              <div class="wz-schedule-cell" role="cell">
                <label class="wz-toggle">
                  <input
                    type="checkbox"
                    data-schedule-monthly-enabled={ext.key}
                    checked={monthDefault}
                  />
                  <span class="wz-toggle__label">{t.enable}</span>
                </label>
                <div class="wz-schedule-topn">
                  <label for={`monthly-topn-${ext.key}`}>{t.topN}</label>
                  <input
                    type="number"
                    id={`monthly-topn-${ext.key}`}
                    min="1"
                    max="30"
                    value={monthTopN}
                    data-schedule-monthly-topn={ext.key}
                  />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>
</div>
