---
import { getExtensionsForLocale } from '@/lib/registry';
import WizardStep1 from './WizardStep1.astro';
import WizardStep2 from './WizardStep2.astro';
import WizardStep3 from './WizardStep3.astro';
import WizardStep4 from './WizardStep4.astro';
import WizardStep5 from './WizardStep5.astro';
import WizardStep6 from './WizardStep6.astro';

interface Props {
  locale: 'en' | 'zh';
}
const { locale } = Astro.props;

const extensions = getExtensionsForLocale(locale);

const STEPS = locale === 'zh'
  ? ['来源', '配置', '计划', '推送', '主题', '导出']
  : ['Sources', 'Configure', 'Schedule', 'Delivery', 'Theme', 'Export'];

const STEP_BLURBS = locale === 'zh'
  ? [
      '选择应出现在你早间简报中的信息来源，并设定初始阅读顺序。',
      '只显示你选择的来源，方便逐一调整细节。',
      '先确认 LLM provider / model，再决定哪些内容应汇入每周和每月回顾摘要。',
      '在不将密钥写入 YAML 的情况下启用推送通知。',
      '为摘要站点选择配色方案，保存于 sources.yaml 并在构建时应用。',
      '审查生成的文件、密钥提醒和后续操作，然后完成 GitHub 配置。',
    ]
  : [
      'Pick the sources that deserve space in your morning briefing and set the reading order.',
      'Only your chosen sources appear here, so you can tune each one without clutter.',
      'Set the LLM endpoint and then choose what should roll up into weekly and monthly summaries.',
      'Enable notifications without ever pasting secrets into YAML.',
      'Pick a colour palette for your digest site. Saved in sources.yaml and applied at build time.',
      'Review generated files, secret reminders, and next actions before the GitHub handoff.',
    ];

const backLabel = locale === 'zh' ? '上一步' : 'Back';
const nextLabel = locale === 'zh' ? '下一步' : 'Next';
const connectTitle = locale === 'zh' ? '部署方式' : 'Deploy Path';
const connectDesc = locale === 'zh'
  ? '先决定最后是手动提交配置，还是用前端 GitHub 连接做一键部署。'
  : 'Choose whether you want to finish with manual config handoff or a browser-side GitHub deploy.';
const connectModeTitle = locale === 'zh' ? 'Connect GitHub 一键部署' : 'One-click with Connect GitHub';
const connectModeMeta = locale === 'zh' ? '浏览器授权 + 仓库直写' : 'Browser auth + direct repo write';
const connectModeDesc = locale === 'zh'
  ? '推荐先授权 GitHub，再继续填写向导。到第 6 步时可以直接写入仓库和 secrets。'
  : 'Recommended for first-time setup. Authorize GitHub first, then write files and secrets directly at Step 6.';
const manualModeTitle = locale === 'zh' ? 'Advanced manual config' : 'Advanced manual config';
const manualModeMeta = locale === 'zh' ? '复制 YAML + 手动加 secrets' : 'Copy YAML + add secrets';
const manualModeDesc = locale === 'zh'
  ? '继续使用生成的 YAML 和 secret 清单，手动提交到自己的仓库。'
  : 'Export YAML blocks and the secret checklist, then commit everything yourself.';
const connectButtonLabel = locale === 'zh' ? '连接' : 'Connect';
const disconnectButtonLabel = locale === 'zh' ? '断开连接' : 'Disconnect';
const patPlaceholder = locale === 'zh' ? '粘贴 Personal Access Token…' : 'Paste Personal Access Token…';
const patHint = locale === 'zh'
  ? '需要 contents:write、metadata:read、actions:write、secrets:write 权限的 Fine-grained PAT；如果想让 Step 6 自动启用 Actions / workflows，再额外加 administration:write。Classic PAT 继续使用 repo + workflow。'
  : 'Fine-grained PAT with contents:write, metadata:read, actions:write, and secrets:write. Add administration:write too if you want Step 6 to auto-enable Actions / workflows. Classic PAT can still use repo + workflow.';
const patCreateLink = 'https://github.com/settings/personal-access-tokens/new';
const patCreateLabel = locale === 'zh' ? '在 GitHub 创建 Token →' : 'Create token on GitHub →';
const patInstructionLabel = locale === 'zh' ? '填写说明' : 'Instructions';
const patInstructionTitle = locale === 'zh' ? '如何创建 GitHub PAT' : 'How to create a GitHub PAT';
const patInstructionClose = locale === 'zh' ? '关闭' : 'Close';
const connectStatusIdle = locale === 'zh'
  ? '尚未连接 GitHub。建议先连接，再开始填写向导。'
  : 'GitHub is not connected yet. Connect first if you want the one-click path.';
const connectSummaryIdle = locale === 'zh'
  ? '未连接时，你仍然可以完成向导并导出配置，但需要自己提交文件和 secrets。'
  : 'You can still complete the wizard without connecting, but you will commit files and secrets yourself.';
---

<div
  class="wz"
  data-locale={locale}
  data-wizard
  data-step-blurbs={JSON.stringify(STEP_BLURBS)}
>

  <section class="wz-entry">
    <div class="wz-entry__bar">
      <div class="wz-entry__copy">
        <div class="wz-entry__eyebrow">{connectTitle}</div>
        <p class="wz-entry__desc">{connectDesc}</p>
      </div>
      <div class="wz-entry__modes">
        <button
          type="button"
          class="wz-entry-chip"
          data-setup-mode-btn="connect"
          aria-pressed="true"
        >
          <span class="wz-entry-chip__title">{connectModeTitle}</span>
          <span class="wz-entry-chip__meta">{connectModeMeta}</span>
        </button>
        <button
          type="button"
          class="wz-entry-chip"
          data-setup-mode-btn="manual"
          aria-pressed="false"
        >
          <span class="wz-entry-chip__title">{manualModeTitle}</span>
          <span class="wz-entry-chip__meta">{manualModeMeta}</span>
        </button>
      </div>
    </div>
    <div class="wz-card" data-setup-mode-panel="connect" hidden={false}>
      <h3>{connectModeTitle}</h3>
      <p class="wz-card__desc">{connectModeDesc}</p>
      <div class="wz-field">
        <input
          type="password"
          class="wz-input"
          data-github-pat-input
          placeholder={patPlaceholder}
          autocomplete="off"
          spellcheck={false}
        />
        <div class="wz-field__hint">
          {patHint}
          {' '}<a href={patCreateLink} target="_blank" rel="noopener">{patCreateLabel}</a>
          {' · '}<button type="button" class="wz-hint-link" data-pat-instruction-btn>{patInstructionLabel}</button>
        </div>
      </div>
      <div class="wz-auth-actions">
        <button type="button" class="wz-btn wz-btn--primary" data-github-connect-btn>
          {connectButtonLabel}
        </button>
        <button type="button" class="wz-btn wz-btn--ghost" data-github-disconnect-btn hidden>
          {disconnectButtonLabel}
        </button>
      </div>
      <div class="wz-notice wz-notice--info" data-github-auth-status>
        {connectStatusIdle}
      </div>
      <div class="wz-auth-summary" data-github-auth-summary>{connectSummaryIdle}</div>
    </div>

    <div class="wz-card" data-setup-mode-panel="manual" hidden={true}>
      <h3>{manualModeTitle}</h3>
      <p class="wz-card__desc">{manualModeDesc}</p>
      <div class="wz-notice wz-notice--info">
        <strong>{locale === 'zh' ? '适合这些情况' : 'Best for'}</strong>
        <div>
          {locale === 'zh'
            ? '你希望继续保持 fork-and-run，不把任何 GitHub 授权状态保留在浏览器里。'
            : 'You want to keep the original fork-and-run model and avoid keeping GitHub auth state in the browser.'}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Progress bar ────────────────────────────────────────── -->
  <nav class="wz-progress" data-progress-anchor aria-label={locale === 'zh' ? '向导进度' : 'Wizard progress'}>
    <div class="wz-progress__bar">
      <div class="wz-progress__fill" data-progress-fill style="width:0%"></div>
    </div>
    <div class="wz-progress__steps">
      {STEPS.map((label, i) => (
        <button
          type="button"
          class="wz-progress__step"
          data-step-btn={i + 1}
          aria-current={i === 0 ? 'step' : 'false'}
        >
          <span class="wz-progress__num">{i + 1}</span>
          <span class="wz-progress__label">{label}</span>
        </button>
      ))}
    </div>
  </nav>

  <!-- ── Step header ─────────────────────────────────────────── -->
  <div class="wz-step-header">
    <div class="wz-step-header__pill" data-step-pill>
      {locale === 'zh' ? '第 1 步 / 共 6 步' : 'Step 1 of 6'}
    </div>
    <p class="wz-step-header__blurb" data-step-blurb>{STEP_BLURBS[0]}</p>
  </div>

  <!-- ── Step panels ─────────────────────────────────────────── -->
  <div class="wz-panels">
    <WizardStep1 {extensions} {locale} />
    <WizardStep2 {extensions} {locale} />
    <WizardStep3 {extensions} {locale} />
    <WizardStep4 {locale} />
    <WizardStep5 {locale} />
    <WizardStep6 {locale} />
  </div>

  <!-- ── Navigation ─────────────────────────────────────────── -->
  <div class="wz-nav">
    <button type="button" class="wz-btn wz-btn--ghost" data-wizard-back disabled>
      {backLabel}
    </button>
    <button type="button" class="wz-btn wz-btn--primary" data-wizard-next>
      {nextLabel}
    </button>
  </div>

</div>

<!-- ── PAT instruction dialog ─────────────────────────────── -->
<dialog class="wz-dialog" id="wz-pat-dialog" aria-label={patInstructionTitle}>
  <div class="wz-dialog__inner">
    <div class="wz-dialog__header">
      <h2 class="wz-dialog__title">{patInstructionTitle}</h2>
      <button type="button" class="wz-dialog__close" data-pat-instruction-close aria-label={patInstructionClose}>✕</button>
    </div>
    <div class="wz-dialog__body">
      {locale === 'zh' ? (
        <>
          <p class="wz-dialog__lead">前往 <a href={patCreateLink} target="_blank" rel="noopener">GitHub → Settings → Developer settings → Personal access tokens</a> 新建 Token，按以下步骤填写：</p>

          <h3 class="wz-dialog__section-title">Fine-grained PAT（推荐）</h3>
          <ol class="wz-dialog__steps">
            <li><strong>Token name</strong>：填写一个描述性名称，例如 <code>linnet-deploy</code></li>
            <li><strong>Expiration</strong>：建议选 90 天或更长</li>
            <li><strong>Resource owner</strong>：选择你的账号（或 Org）</li>
            <li><strong>Repository access</strong>：选 <em>Only select repositories</em>，然后勾选你的 Linnet fork</li>
            <li><strong>Permissions</strong>（展开 Repository permissions）：
              <ul class="wz-dialog__perms">
                <li><code>Contents</code> → <strong>Read and write</strong></li>
                <li><code>Metadata</code> → <strong>Read</strong>（强制自动勾选）</li>
                <li><code>Actions</code> → <strong>Read and write</strong></li>
                <li><code>Secrets</code> → <strong>Read and write</strong></li>
                <li><code>Administration</code> → <strong>Read and write</strong>（仅在你想让 Step 6 自动启用 Actions / workflows 时需要）</li>
              </ul>
            </li>
            <li>点击 <strong>Generate token</strong>，立即复制（仅显示一次）</li>
          </ol>

          <h3 class="wz-dialog__section-title">Classic PAT（操作更简单，权限范围更广）</h3>
          <ol class="wz-dialog__steps">
            <li><strong>Token name</strong>：例如 <code>linnet-deploy</code></li>
            <li><strong>Expiration</strong>：自选</li>
            <li><strong>Scopes</strong>：勾选 <code>repo</code>（全部子项）和 <code>workflow</code></li>
            <li>点击 <strong>Generate token</strong>，立即复制（仅显示一次）</li>
          </ol>
        </>
      ) : (
        <>
          <p class="wz-dialog__lead">Go to <a href={patCreateLink} target="_blank" rel="noopener">GitHub → Settings → Developer settings → Personal access tokens</a> and create a new token:</p>

          <h3 class="wz-dialog__section-title">Fine-grained PAT (recommended)</h3>
          <ol class="wz-dialog__steps">
            <li><strong>Token name</strong> — something descriptive, e.g. <code>linnet-deploy</code></li>
            <li><strong>Expiration</strong> — 90 days or longer recommended</li>
            <li><strong>Resource owner</strong> — your account or org</li>
            <li><strong>Repository access</strong> — choose <em>Only select repositories</em>, then pick your Linnet fork</li>
            <li><strong>Permissions</strong> — expand <em>Repository permissions</em> and set:
              <ul class="wz-dialog__perms">
                <li><code>Contents</code> → <strong>Read and write</strong></li>
                <li><code>Metadata</code> → <strong>Read</strong> (auto-selected, required)</li>
                <li><code>Actions</code> → <strong>Read and write</strong></li>
                <li><code>Secrets</code> → <strong>Read and write</strong></li>
                <li><code>Administration</code> → <strong>Read and write</strong> (only if you want Step 6 to auto-enable Actions / workflows)</li>
              </ul>
            </li>
            <li>Click <strong>Generate token</strong> and copy it immediately — it is shown only once</li>
          </ol>

          <h3 class="wz-dialog__section-title">Classic PAT (simpler, broader access)</h3>
          <ol class="wz-dialog__steps">
            <li><strong>Token name</strong> — e.g. <code>linnet-deploy</code></li>
            <li><strong>Expiration</strong> — pick a duration</li>
            <li><strong>Scopes</strong> — check <code>repo</code> (all sub-scopes) and <code>workflow</code></li>
            <li>Click <strong>Generate token</strong> and copy immediately — shown only once</li>
          </ol>
        </>
      )}
    </div>
  </div>
</dialog>

<script>
  import { initWizard } from './wizardController';
  initWizard();

  const dialog = document.getElementById('wz-pat-dialog') as HTMLDialogElement | null;
  document.querySelector('[data-pat-instruction-btn]')?.addEventListener('click', () => {
    dialog?.showModal();
  });
  document.querySelector('[data-pat-instruction-close]')?.addEventListener('click', () => {
    dialog?.close();
  });
  dialog?.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>

<style is:global>
/* ── Shell ──────────────────────────────────────────────────── */
.wz {
  font-family: var(--font-body);
  color: var(--ink);
  max-width: 1200px;
  margin: 0 auto;
}

.wz-entry {
  margin-bottom: 48px;
  padding: 32px;
  background: var(--bg-deep);
  border: 1px solid var(--rule);
}

.wz-entry__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
  margin-bottom: 12px;
}

.wz-entry__desc {
  margin: 0;
  color: var(--ink-soft);
  line-height: 1.7;
  font-size: 0.875rem;
  max-width: 50ch;
}

.wz-entry__bar {
  display: flex;
  justify-content: space-between;
  gap: 32px;
  align-items: flex-start;
  margin-bottom: 24px;
}

.wz-entry__copy {
  flex: 1;
}

.wz-entry__modes {
  display: flex;
  gap: 8px;
  background: var(--bg);
  padding: 4px;
  border: 1px solid var(--rule);
}

.wz-entry-chip {
  min-width: 240px;
  padding: 14px 18px;
  border: none;
  background: transparent;
  cursor: pointer;
  transition: all 0.2s ease;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.wz-entry-chip__title {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink);
  line-height: 1.15;
}

.wz-entry-chip__meta {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

.wz-entry-chip[aria-pressed="true"] {
  background: var(--paper);
  color: var(--ink);
  box-shadow: var(--shadow);
}

.wz-entry__hint {
  margin-top: -8px;
  margin-bottom: 24px;
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.08em;
  color: var(--ink-muted);
  line-height: 1.7;
}

.wz-auth-actions {
  display: flex;
  gap: 12px;
  align-items: center;
  margin: 16px 0;
}

.wz-auth-summary {
  color: var(--ink-soft);
  line-height: 1.65;
}

.wz-user-badge {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 16px;
  background: var(--bg);
  border: 1px solid var(--rule);
  margin-bottom: 8px;
}

.wz-user-badge__avatar {
  width: 48px;
  height: 48px;
  border-radius: 4px;
  border: 1px solid var(--rule);
}

.wz-user-badge__info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.wz-user-badge__name {
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.2;
}

.wz-user-badge__meta {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  color: var(--ink-muted);
  letter-spacing: 0.02em;
}

/* ── Progress bar ──────────────────────────────────────────── */
.wz-progress {
  margin-bottom: 48px;
}

.wz-progress__bar {
  height: 1px;
  background: var(--rule);
  margin-bottom: 24px;
  position: relative;
}

.wz-progress__fill {
  position: absolute;
  inset: 0 auto 0 0;
  background: var(--accent);
  height: 2px;
  top: -0.5px;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.wz-progress__steps {
  display: flex;
  justify-content: space-between;
  gap: 0;
}

.wz-progress__step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  flex: 1;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-muted);
  transition: all 0.3s ease;
  position: relative;
}

.wz-progress__step[aria-current="step"] { color: var(--accent); }
.wz-progress__step[data-complete="true"] { color: var(--ink); }

.wz-progress__num {
  font-family: var(--font-display);
  font-size: 0.875rem;
  font-weight: 700;
  width: 28px;
  height: 28px;
  border: 1px solid var(--rule);
  border-radius: 50%;
  display: grid;
  place-items: center;
  background: var(--paper);
  transition: all 0.3s ease;
  z-index: 2;
}

.wz-progress__step[aria-current="step"] .wz-progress__num {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg);
  transform: scale(1.1);
  box-shadow: 0 0 0 4px var(--accent-soft);
}

.wz-progress__step[data-complete="true"] .wz-progress__num {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--bg);
}

.wz-progress__label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-weight: 700;
}

/* ── Step header ───────────────────────────────────────────── */
.wz-step-header {
  margin-bottom: 40px;
  text-align: center;
}

.wz-step-header__pill {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
  margin-bottom: 12px;
}

.wz-step-header__blurb {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.25rem;
  color: var(--ink-soft);
  line-height: 1.5;
  max-width: 32ch;
  margin: 0 auto;
}

/* ── Step panels ───────────────────────────────────────────── */
.wz-panels { position: relative; }

.wz-step { display: none; }
.wz-step[aria-hidden="false"] { display: block; }

/* ── Navigation ────────────────────────────────────────────── */
.wz-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24px;
  margin-top: 24px;
  border-top: 1px solid var(--rule);
}

/* ── Buttons ────────────────────────────────────────────────── */
.wz-btn {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  padding: 10px 28px;
  border: 1px solid var(--ink);
  cursor: pointer;
  transition: all 0.2s ease;
  text-decoration: none;
  font-weight: 700;
}

.wz-btn--primary {
  background: var(--ink);
  color: var(--bg);
}
.wz-btn--primary:hover {
  background: var(--accent);
  border-color: var(--accent);
  transform: translateY(-1px);
}
.wz-btn--ghost { background: transparent; color: var(--ink); }
.wz-btn--ghost:hover {
  background: var(--bg-deep);
}
.wz-btn:disabled { opacity: 0.25; cursor: not-allowed; }

/* ── Cards ──────────────────────────────────────────────────── */
.wz-card {
  border: 1px solid var(--rule);
  padding: 32px;
  background: var(--paper);
  margin-bottom: 24px;
}

.wz-card h3 {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin: 0 0 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--rule-soft);
}

.wz-card__desc {
  font-size: 0.875rem;
  color: var(--ink-soft);
  line-height: 1.65;
  margin: 0 0 18px;
  max-width: 62ch;
}

.wz-card__header {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  align-items: start;
}

/* ── Stack ──────────────────────────────────────────────────── */
.wz-stack { display: flex; flex-direction: column; gap: 24px; }

.wz-field-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}

/* ── Slider ─────────────────────────────────────────────────── */
.wz-slider-row {
  display: flex;
  align-items: center;
  gap: 16px;
  min-height: 46px;
  padding: 10px 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
}

.wz-slider-row input[type="range"] {
  flex: 1;
  accent-color: var(--accent);
}

.wz-slider-val {
  font-family: var(--font-mono);
  font-size: 0.875rem;
  min-width: 2.5ch;
  text-align: right;
  color: var(--ink);
  font-weight: 700;
}

/* ── Multi-select chips ─────────────────────────────────────── */
.wz-multiselect {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  padding: 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
}

.wz-chip-label { cursor: pointer; }
.wz-chip-label input[type="checkbox"] { display: none; }

.wz-chip {
  display: inline-flex;
  flex-direction: column;
  gap: 2px;
  padding: 8px 16px;
  border: 1px solid var(--rule);
  background: var(--paper);
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.08em;
  font-weight: 700;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.2s ease;
  color: var(--ink-muted);
}

.wz-chip__sub {
  font-size: 0.63rem;
  color: var(--ink-muted);
  font-family: var(--font-body);
  letter-spacing: 0;
  text-transform: none;
  font-weight: 400;
}

.wz-chip-label input:checked + .wz-chip {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg);
}

.wz-chip-label input:checked + .wz-chip .wz-chip__sub { color: rgba(255,255,255,0.7); }

/* ── Tags / URLs input ──────────────────────────────────────── */
.wz-tags, .wz-urls {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
}

.wz-tags__list, .wz-urls__list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  min-height: 32px;
}

.wz-tags__empty, .wz-urls__empty {
  font-size: 0.875rem;
  color: var(--ink-muted);
  font-style: italic;
}

.wz-tags__input-row, .wz-urls__input-row {
  display: flex;
  gap: 10px;
}

.wz-tags__input, .wz-urls__input {
  flex: 1;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  min-height: 42px;
  padding: 8px 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
  color: var(--ink);
  outline: none;
}

.wz-tags__add, .wz-urls__add {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  min-height: 42px;
  padding: 8px 16px;
  border: 1px solid var(--ink);
  background: transparent;
  color: var(--ink);
  font-weight: 700;
  cursor: pointer;
}

.wz-tags__add:hover, .wz-urls__add:hover {
  background: var(--ink);
  color: var(--bg);
}

.wz-tag, .wz-url-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 4px 10px;
  border: 1px solid var(--rule);
  background: var(--bg-deep);
  font-family: var(--font-mono);
  font-size: 0.69rem;
  color: var(--ink-soft);
  font-weight: 600;
}

.wz-tag__remove, .wz-url-item__remove {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-muted);
  font-size: 1rem;
  padding: 0;
  line-height: 1;
}

.wz-tag__remove:hover, .wz-url-item__remove:hover { color: var(--accent); }

.wz-field-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}

.wz-field-row .wz-field { min-width: 0; }

.wz-field-stack { display: flex; flex-direction: column; gap: 20px; }
.wz-field { display: flex; flex-direction: column; gap: 8px; }

.wz-field--rich {
  padding: 16px;
  border: 1px solid var(--rule);
  background: var(--paper);
}

.wz-field label,
.wz-field__label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

.wz-field input[type="text"],
.wz-field input[type="password"],
.wz-field input[type="number"],
.wz-field input[type="url"],
.wz-field select {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  width: 100%;
  min-height: 46px;
  padding: 10px 14px;
  border: 1px solid var(--rule);
  background: var(--bg);
  color: var(--ink);
  outline: none;
  transition: all 0.2s ease;
}

.wz-field input:focus,
.wz-field select:focus {
  border-color: var(--ink);
  background: var(--paper);
  box-shadow: 0 0 0 3px var(--accent-soft);
}

.wz-field__hint {
  font-size: 0.8125rem;
  color: var(--ink-muted);
  line-height: 1.6;
  font-style: italic;
}

.wz-switch {
  display: flex;
  gap: 12px;
  align-items: flex-start;
  padding: 14px 16px;
  border: 1px solid var(--rule);
  background: var(--bg);
  cursor: pointer;
}

.wz-switch input[type="checkbox"] {
  margin: 2px 0 0;
  inline-size: 18px;
  block-size: 18px;
  accent-color: var(--accent);
  flex: 0 0 auto;
}

.wz-switch > span {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

/* ── arXiv profile grid ─────────────────────────────────────── */
.wz-profile-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 12px;
  margin-top: 12px;
}

.wz-profile-card {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 16px;
  border: 1px solid var(--rule);
  background: var(--paper);
  cursor: pointer;
  transition: all 0.2s ease;
}

.wz-profile-card input { display: none; }

.wz-profile-card:hover { border-color: var(--ink-soft); }

.wz-profile-card:has(input:checked) {
  border-color: var(--accent);
  background: var(--accent-soft);
  box-shadow: 0 2px 12px rgba(0,0,0,0.05);
}

.wz-profile-card__name {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  color: var(--ink);
}

.wz-profile-card__summary {
  font-family: var(--font-body);
  font-size: 0.8125rem;
  color: var(--ink-muted);
  line-height: 1.5;
}

/* ── Toggle ─────────────────────────────────────────────────── */
.wz-toggle {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
}

.wz-toggle input[type="checkbox"] {
  width: 40px; height: 22px;
  appearance: none;
  background: var(--rule);
  border-radius: 20px;
  cursor: pointer;
  position: relative;
  transition: background 0.2s;
  flex-shrink: 0;
}

.wz-toggle input[type="checkbox"]::after {
  content: '';
  position: absolute;
  top: 3px; left: 3px;
  width: 16px; height: 16px;
  background: var(--paper);
  border-radius: 50%;
  transition: left 0.2s;
}

.wz-toggle input[type="checkbox"]:checked {
  background: var(--accent);
}

.wz-toggle input[type="checkbox"]:checked::after { left: 21px; }

.wz-toggle__label {
  font-family: var(--font-mono);
  font-size: 0.69rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

/* ── Notices ────────────────────────────────────────────────── */
.wz-notice {
  padding: 16px 20px;
  border: 1px solid var(--rule);
  border-left: 4px solid var(--rule);
  font-family: var(--font-body);
  font-size: 0.9375rem;
  line-height: 1.7;
  color: var(--ink-soft);
  margin-bottom: 24px;
}

.wz-notice strong {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--ink);
  display: block;
  margin-bottom: 6px;
}
.wz-notice--info  { border-left-color: var(--accent); background: var(--paper); }
.wz-notice--warn  { border-left-color: var(--gold); background: var(--paper); }
.wz-notice--success { border-left-color: var(--sage); background: var(--paper); }

.wz-checklist {
  margin: 8px 0 0;
  padding-left: 20px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

/* ── Step 1 layout ──────────────────────────────────────────── */
.wz-step1-layout {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 48px;
  align-items: start;
}

.wz-search {
  width: 100%;
  font-family: var(--font-body);
  font-size: 1rem;
  padding: 12px 0;
  border: none;
  border-bottom: 2px solid var(--rule);
  background: transparent;
  color: var(--ink);
  margin-bottom: 24px;
  outline: none;
  transition: border-color 0.2s;
}
.wz-search:focus { border-color: var(--accent); }

.wz-filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 32px;
}

.wz-filter-chips .wz-chip {
  background: var(--bg-deep);
  border: 1px solid var(--rule);
  color: var(--ink-muted);
  padding: 6px 14px;
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.wz-filter-chips .wz-chip--active,
.wz-filter-chips .wz-chip[aria-pressed="true"] {
  background: var(--accent);
  border-color: var(--accent);
  color: var(--bg);
}

.wz-ext-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 20px;
  max-height: 600px;
  overflow-y: auto;
  padding-right: 12px;
}

/* Scrollbar styling for editorial feel */
.wz-ext-grid::-webkit-scrollbar { width: 4px; }
.wz-ext-grid::-webkit-scrollbar-track { background: var(--rule-soft); }
.wz-ext-grid::-webkit-scrollbar-thumb { background: var(--rule); }

.wz-ext-card {
  position: relative;
  padding: 24px;
  border: 1px solid var(--rule);
  background: var(--paper);
  text-align: left;
  cursor: pointer;
  transition: all 0.2s ease;
  min-height: 180px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.wz-ext-card:hover {
  border-color: var(--ink);
  transform: translateY(-2px);
  box-shadow: var(--shadow);
}

.wz-ext-card[aria-pressed="true"] {
  border-color: var(--accent);
  background: var(--accent-soft);
}

.wz-ext-card__check {
  position: absolute;
  top: 16px; right: 16px;
  font-size: 0.75rem;
  color: var(--bg);
  background: var(--accent);
  width: 22px; height: 22px;
  border-radius: 50%;
  display: grid; place-items: center;
  opacity: 0;
  transform: scale(0.5);
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.wz-ext-card[aria-pressed="true"] .wz-ext-card__check {
  opacity: 1;
  transform: scale(1);
}

.wz-ext-card__name {
  font-family: var(--font-display);
  font-size: 1.125rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--ink);
  line-height: 1.2;
}

.wz-ext-card__desc {
  font-family: var(--font-body);
  font-size: 0.875rem;
  color: var(--ink-soft);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}

.wz-ext-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: auto;
}

.wz-label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  padding: 2px 8px;
  background: var(--bg-deep);
  color: var(--ink-muted);
  border: none;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.wz-label--ghost {
  background: transparent;
  border: 1px solid var(--rule);
}

/* ── Step 2 configure sheet ─────────────────────────────────── */
.wz-step2-sheet {
  background: var(--paper);
  border: 1px solid var(--rule);
  padding: 8px 32px 24px;
}

.wz-step2-section {
  padding: 24px 0 0;
}

.wz-step2-section--lead {
  padding-top: 16px;
}

.wz-step2-divider {
  height: 1px;
  background: var(--rule);
  margin-bottom: 24px;
}

.wz-step2-section__head {
  margin-bottom: 18px;
}

.wz-step2-section__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 700;
  margin-bottom: 10px;
}

.wz-step2-subhead {
  margin: 22px 0 14px;
  padding-top: 18px;
  border-top: 1px dashed var(--rule);
}

.wz-step2-subhead strong {
  font-family: var(--font-display);
  font-size: 1rem;
  color: var(--ink);
  display: block;
  margin-bottom: 6px;
}

/* ── Step 1 order panel ─────────────────────────────────────── */
.wz-step1-order {
  position: sticky;
  top: 80px;
  padding: 24px;
  background: var(--bg-deep);
  border: 1px solid var(--rule);
}

.wz-order-head {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--rule);
}

.wz-order-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-height: 48px;
}

.wz-order-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  border: 1px solid var(--rule);
  background: var(--paper);
  cursor: grab;
  user-select: none;
  font-family: var(--font-body);
  font-size: 0.9375rem;
  color: var(--ink);
  transition: all 0.2s ease;
}

.wz-order-item:hover {
  border-color: var(--ink);
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.wz-order-item:active { cursor: grabbing; }
.wz-order-item.wz-order-item--drag-over {
  border-color: var(--accent);
  background: var(--accent-soft);
}

.wz-order-item__handle {
  font-size: 0.875rem;
  color: var(--ink-muted);
  opacity: 0.5;
}

.wz-order-item__name {
  flex: 1;
  font-weight: 600;
}

[hidden] {
  display: none !important;
}

/* ── Step 3 schedule table ───────────────────────────────────── */
.wz-schedule-table { display: flex; flex-direction: column; gap: 0; }

.wz-schedule-table__head {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
  padding: 8px 16px;
  border-bottom: 2px solid var(--ink);
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
}

.wz-schedule-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
  padding: 12px 16px;
  border-bottom: 1px solid var(--rule);
  align-items: start;
}

.wz-schedule-row__name {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--ink);
  padding-top: 4px;
}

.wz-schedule-cell { display: flex; flex-direction: column; gap: 8px; }

.wz-schedule-topn {
  display: flex;
  align-items: center;
  gap: 8px;
}

.wz-schedule-topn label {
  font-size: 0.75rem;
  color: var(--ink-muted);
}

.wz-schedule-topn input {
  width: 60px;
  padding: 4px 8px;
  border: 1px solid var(--rule);
  background: var(--bg);
  color: var(--ink);
  font-family: var(--font-mono);
  font-size: 0.8rem;
  outline: none;
}

.wz-schedule-topn input:focus { border-color: var(--accent); }

/* ── Sink fields ─────────────────────────────────────────────── */
.wz-sink-fields { display: flex; flex-direction: column; gap: 16px; margin-top: 16px; }

/* ── Theme presets ──────────────────────────────────────────── */
.wz-theme-columns {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24px;
  align-items: start;
}

.wz-theme-col {
  display: flex;
  flex-direction: column;
  gap: 18px;
  min-width: 0;
}

.wz-theme-col__label,
.wz-theme-section__label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  font-weight: 700;
}

.wz-theme-section {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 20px;
  border: 1px solid var(--rule);
  background: var(--paper);
}

.wz-preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 8px;
}

.wz-theme-preview-card {
  overflow: hidden;
}

.wz-theme-preview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
  margin-top: 18px;
}

.wz-theme-preview {
  --preview-bg: var(--bg);
  --preview-paper: var(--paper);
  --preview-ink: var(--ink);
  --preview-soft: var(--ink-soft);
  --preview-accent: var(--accent);
  --preview-rule: var(--rule);
  --preview-glow: var(--accent-soft);
}

.wz-theme-preview__label {
  font-family: var(--font-mono);
  font-size: 0.63rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin-bottom: 10px;
}

.wz-theme-preview__surface {
  background: var(--preview-bg);
  border: 1px solid var(--preview-rule);
  padding: 18px;
  min-height: 240px;
  display: flex;
  flex-direction: column;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.wz-theme-preview__nav,
.wz-theme-preview__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.wz-theme-preview__footer {
  margin-top: auto;
}

.wz-theme-preview__brand,
.wz-theme-preview__cta {
  font-family: var(--font-mono);
  font-size: 0.66rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--preview-ink);
  font-weight: 700;
}

.wz-theme-preview__badge,
.wz-theme-preview__pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 24px;
  padding: 0 10px;
  border-radius: 999px;
  background: var(--preview-glow);
  color: var(--preview-accent);
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 700;
}

.wz-theme-preview__hero {
  margin: 26px 0 30px;
}

.wz-theme-preview__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--preview-accent);
  font-weight: 700;
  margin-bottom: 10px;
}

.wz-theme-preview__hero h4 {
  font-family: var(--font-display);
  font-size: 1.9rem;
  line-height: 0.98;
  letter-spacing: -0.04em;
  color: var(--preview-ink);
  margin: 0 0 14px;
}

.wz-theme-preview__hero p {
  font-family: var(--font-body);
  font-size: 0.92rem;
  line-height: 1.65;
  color: var(--preview-soft);
  margin: 0;
  max-width: 28ch;
}

.wz-preset {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  border: 1px solid var(--rule);
  background: var(--bg);
  cursor: pointer;
  font-size: 0.8rem;
  color: var(--ink-soft);
  transition: border-color 0.15s;
}

.wz-preset[aria-pressed="true"] {
  border-color: var(--accent);
  color: var(--ink);
}

.wz-preset__swatch {
  width: 16px; height: 16px;
  border: 1px solid rgba(0,0,0,0.12);
  display: inline-block;
  flex-shrink: 0;
}

.wz-preset__swatch--dashed { border: 1px dashed var(--rule); background: transparent; }

.wz-custom-color {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 10px;
}

.wz-custom-color input[type="color"] {
  width: 36px; height: 28px;
  padding: 2px;
  border: 1px solid var(--rule);
  cursor: pointer;
  background: var(--bg);
}

.wz-custom-color input[type="text"] {
  width: 100px;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  padding: 4px 8px;
  border: 1px solid var(--rule);
  background: var(--bg);
  color: var(--ink);
  outline: none;
}

.wz-custom-color input[type="text"]:focus { border-color: var(--accent); }

/* ── arXiv profile grid ─────────────────────────────────────── */
.wz-profile-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 8px;
  margin-top: 8px;
}

.wz-profile-card {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 10px 14px;
  border: 1px solid var(--rule);
  cursor: pointer;
  transition: border-color 0.15s;
}

.wz-profile-card input { display: none; }

