<style>
.daily-nav-panel {
  width: 250px;
  padding: 0.9rem 1rem;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 10px;
  position: fixed;
  left: 1rem;
  bottom: 1rem;
  z-index: 30;
  max-height: 62vh;
  overflow: auto;
  background: rgba(20, 24, 32, 0.94);
  font-size: 0.92rem;
}

.daily-nav-title {
  font-weight: 700;
  margin-bottom: 0.4rem;
}

.daily-nav-panel ul,
.daily-nav-mobile ul {
  margin: 0.35rem 0 0 1rem;
}

.daily-nav-mobile {
  display: none;
  margin-bottom: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 8px;
  padding: 0.55rem 0.7rem;
}

@media (max-width: 900px) {
  .daily-nav-panel {
    display: none;
  }

  .daily-nav-mobile {
    display: block;
  }
}
</style>

<aside class="daily-nav-panel" aria-label="页面导航">
  <div class="daily-nav-title">快速导航</div>
  <ul>
    <li><a href="#arxiv">arXiv 精选</a></li>
    {% if papers %}
    <li>论文分类
      <ul>
        {% set nav_ns = namespace(seen=[]) %}
        {% for p in papers %}
          {% set category_name = p.get('primary_category', (p.categories[0] if p.categories else 'Other')) %}
          {% set category_anchor = p.get('primary_category_anchor', category_name | lower | replace('.', '-') | replace(' ', '-') | replace('/', '-')) %}
          {% if category_anchor not in nav_ns.seen %}
          <li><a href="#cat-{{ category_anchor }}">{{ category_name }}</a></li>
          {% set _ = nav_ns.seen.append(category_anchor) %}
          {% endif %}
        {% endfor %}
      </ul>
    </li>
    {% endif %}
    <li><a href="#hacker-news">Hacker News</a></li>
    <li><a href="#jobs">研究职位</a></li>
    {% if github_trending %}
    <li><a href="#github-trending">GitHub 趋势</a></li>
    {% endif %}
    {% if supervisor_updates %}
    <li><a href="#supervisors">导师主页更新</a></li>
    {% endif %}
  </ul>
</aside>

<details class="daily-nav-mobile">
  <summary><strong>快速导航</strong></summary>
  <ul>
    <li><a href="#arxiv">arXiv 精选</a></li>
    {% if papers %}
    <li>论文分类
      <ul>
        {% set nav_mobile_ns = namespace(seen=[]) %}
        {% for p in papers %}
          {% set category_name = p.get('primary_category', (p.categories[0] if p.categories else 'Other')) %}
          {% set category_anchor = p.get('primary_category_anchor', category_name | lower | replace('.', '-') | replace(' ', '-') | replace('/', '-')) %}
          {% if category_anchor not in nav_mobile_ns.seen %}
          <li><a href="#cat-{{ category_anchor }}">{{ category_name }}</a></li>
          {% set _ = nav_mobile_ns.seen.append(category_anchor) %}
          {% endif %}
        {% endfor %}
      </ul>
    </li>
    {% endif %}
    <li><a href="#hacker-news">Hacker News</a></li>
    <li><a href="#jobs">研究职位</a></li>
    {% if github_trending %}
    <li><a href="#github-trending">GitHub 趋势</a></li>
    {% endif %}
    {% if supervisor_updates %}
    <li><a href="#supervisors">导师主页更新</a></li>
    {% endif %}
  </ul>
</details>

---

<h2 id="arxiv">📄 今日 arXiv 精选（{{ papers|length }} 篇）</h2>

{% if papers %}
{% set content_ns = namespace(seen=[]) %}
{% for p in papers %}
{% set category_name = p.get('primary_category', (p.categories[0] if p.categories else 'Other')) %}
{% set category_anchor = p.get('primary_category_anchor', category_name | lower | replace('.', '-') | replace(' ', '-') | replace('/', '-')) %}
{% if category_anchor not in content_ns.seen %}
<h3 id="cat-{{ category_anchor }}">{{ category_name }}</h3>
{% set _ = content_ns.seen.append(category_anchor) %}
{% endif %}

<h4>{{ loop.index }}. <a href="{{ p.url }}">{{ p.title }}</a></h4>

**作者：** {{ p.authors | join(', ') }} | **分类：** {{ p.categories | join(', ') }} | **评分：** {{ "%.1f"|format(p.score) }}/10

{% if p.figure_url %}
![{{ p.figure_caption or p.title }}]({{ p.figure_url }})
{% if p.figure_caption %}
*Figure 1.* {{ p.figure_caption }}
{% endif %}
{% endif %}

{{ p.abstract_zh }}

---
{% endfor %}
{% else %}
{% if meta.get('papers_after_keyword_filter', 0) > 0 %}
*今日无最终入选论文。关键词预筛后共有 {{ meta.papers_after_keyword_filter }} 篇候选，但 LLM 评分后为 0；这通常意味着模型过滤过严或评分请求失败。*
{% else %}
*今日无符合条件的论文。*
{% endif %}
{% endif %}

<h2 id="hacker-news">🔥 Hacker News 科技热点（{{ hacker_news|length }} 条）</h2>

{% if hacker_news %}
{% for s in hacker_news %}
- **[{{ s.title }}]({{ s.url }})** ({{ s.score }}pts) — {{ s.summary_zh }} [[评论]({{ s.comments_url }})]
{% endfor %}
{% else %}
*今日无符合条件的热点。*
{% endif %}

<h2 id="jobs">💼 最新博士后 / 研究职位（{{ jobs|length }} 个）</h2>

{% if jobs %}
{% for j in jobs %}
### [{{ j.title }}]({{ j.url }})

**机构：** {{ j.institution or '未知' }} | **地点：** {{ j.location or '未注明' }} | **来源：** {{ j.source }} | **截止：** {{ j.deadline or '未注明' }} | **相关度：** {{ "%.1f"|format(j.relevance_score) }}/10

{% if j.salary %}
**薪资：** {{ j.salary }}
{% endif %}

{{ j.requirements_zh }}

---
{% endfor %}
{% else %}
*今日无新职位更新。*
{% endif %}

{% if github_trending %}
<h2 id="github-trending">🔥 GitHub 今日趋势（{{ github_trending|length }} 个）</h2>

{% for r in github_trending %}
- **[{{ r.full_name }}]({{ r.url }})** {% if r.language %}· {{ r.language }}{% endif %} {% if r.stars_today %}· ⭐ +{{ r.stars_today }} 今日{% elif r.total_stars %}· ⭐ {{ r.total_stars }}{% endif %}

  {{ r.description | replace('\n', ' ') | truncate(100, True, '…') }}{% if r.summary_zh %}
  > {{ r.summary_zh }}{% endif %}

{% endfor %}
{% endif %}

{% if supervisor_updates %}
<h2 id="supervisors">👨‍🏫 导师主页更新</h2>

{% for u in supervisor_updates %}
- **{{ u.name }}**（{{ u.institution }}）— {{ u.change_summary_zh }} [[主页]({{ u.url }})]
{% endfor %}
{% endif %}

