<style>
/* ── Quick nav panel (desktop, fixed) ───────────────────────────── */
.daily-nav-panel {
  width: 200px;
  padding: 1rem 1.1rem;
  border: 1px solid #21262d;
  border-radius: 10px;
  position: fixed;
  right: 1.5rem;
  top: 8rem;
  z-index: 30;
  max-height: 70vh;
  overflow: auto;
  background: #161b22;
  font-size: 0.78rem;
  scrollbar-width: thin;
}

.daily-nav-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #58a6ff;
  margin-bottom: 0.75rem;
}

.daily-nav-panel ul {
  margin: 0.25rem 0 0 0.75rem;
  list-style: none;
  padding: 0;
}

.daily-nav-panel > ul {
  margin-left: 0;
}

.daily-nav-panel a {
  color: #8b949e;
  text-decoration: none;
  display: block;
  padding: 0.15rem 0;
  transition: color 0.15s;
}

.daily-nav-panel a:hover {
  color: #58a6ff;
}

/* ── Mobile nav (collapsible) ────────────────────────────────────── */
.daily-nav-mobile {
  display: none;
  margin-bottom: 1.5rem;
  border: 1px solid #21262d;
  border-radius: 8px;
  background: #161b22;
  font-size: 0.83rem;
}

.daily-nav-mobile summary {
  padding: 0.6rem 0.9rem;
  cursor: pointer;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #58a6ff;
  list-style: none;
}

.daily-nav-mobile ul {
  margin: 0 0 0.5rem 1.25rem;
  padding: 0 0 0.5rem 0;
  list-style: none;
}

.daily-nav-mobile a {
  color: #8b949e;
  text-decoration: none;
  display: block;
  padding: 0.15rem 0;
}

.daily-nav-mobile a:hover { color: #58a6ff; }

@media (max-width: 1100px) {
  .daily-nav-panel { display: none; }
  .daily-nav-mobile { display: block; }
}
</style>

